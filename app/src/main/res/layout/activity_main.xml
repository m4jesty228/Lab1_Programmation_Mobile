<?xml version="1.0" encoding="utf-8"?>
<!-- LinearLayout : conteneur vertical qui empile les éléments de haut en bas -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <!-- Bouton Afficher un message en haut: déclence l'affichage du Toast -->
    <Button
        android:id="@+id/btn_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Afficher un message" />

    <!-- TextView au centre: affiche la valeur du compteur -->
    <TextView
        android:id="@+id/txt_count"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="0"
        android:textSize="96sp"
        android:textColor="#3F51B5"
        android:gravity="center"
        android:background="#FF00FF" />

    <!-- Bouton Incrémenter le compteur en bas: incrémente le compteur -->
    <Button
        android:id="@+id/btn_incrementer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Incrémenter le compteur" />

</LinearLayout>